{
  "name": "@my-react/react-lynx",
  "description": "MyReact renderer for Lynx dual-thread architecture",
  "author": "MrWangJustToDo",
  "license": "MIT",
  "version": "0.0.7",
  "type": "module",
  "main": "./dist/runtime/index.js",
  "types": "./dist/runtime/index.d.ts",
  "files": [
    "dist",
    "client",
    "shims",
    "scripts",
    "package.json",
    "readme.md",
    "jsx-runtime.d.ts",
    "jsx-runtime.js",
    "jsx-namespace.d.ts",
    "jsx-dev-runtime.d.ts",
    "jsx-dev-runtime.js"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MrWangJustToDo/MyReact",
    "directory": "packages/myreact-lynx"
  },
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./jsx-runtime": {
      "import": "./jsx-runtime.js",
      "types": "./jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./jsx-dev-runtime.js",
      "types": "./jsx-dev-runtime.d.ts"
    },
    "./entry-background": {
      "types": "./dist/runtime/entry-background.d.ts",
      "import": "./dist/runtime/entry-background.js"
    },
    "./main-thread": {
      "types": "./dist/main-thread/entry-main.d.ts",
      "import": "./dist/main-thread/entry-main.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./plugin/loaders/*": {
      "import": "./dist/plugin/loaders/*.js"
    },
    "./shims/lynx-react-internal": {
      "types": "./dist/shims/lynx-react-internal.d.ts",
      "import": "./dist/shims/lynx-react-internal.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch",
    "postinstall": "node scripts/postinstall.js"
  },
  "dependencies": {
    "@lynx-js/chunk-loading-webpack-plugin": "^0.4.0",
    "@lynx-js/css-extract-webpack-plugin": "^0.8.0",
    "@lynx-js/gesture-runtime": "^2.1.3",
    "@lynx-js/react": "^0.122.1",
    "@lynx-js/runtime-wrapper-webpack-plugin": "^0.2.1",
    "@lynx-js/template-webpack-plugin": "^0.12.2",
    "@lynx-js/webpack-dev-transport": "^0.3.0",
    "@my-react/react-refresh": "^0.3.28",
    "@my-react/react-refresh-tools": "^0.0.39"
  },
  "devDependencies": {
    "@lynx-js/type-element-api": "0.0.8",
    "@lynx-js/types": "4.0.0",
    "@my-react/react-shared": "^0.3.28",
    "@rsbuild/core": "2.0.11",
    "@rslib/core": "^0.23.2",
    "@rspack/core": "2.0.8",
    "@types/react": "catalog:"
  },
  "peerDependencies": {
    "@lynx-js/gesture-runtime": ">=2.0.0",
    "@my-react/react": ">=0.3.28",
    "@rsbuild/core": ">=2.0.0",
    "@rspack/core": ">=2.0.0"
  },
    "peerDependenciesMeta": {
    "@lynx-js/gesture-runtime": {
      "optional": true
    },
    "@rsbuild/core": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    }
  }
}
