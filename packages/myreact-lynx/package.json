{
  "name": "@my-react/react-lynx",
  "description": "MyReact renderer for Lynx dual-thread architecture",
  "author": "MrWangJustToDo",
  "license": "MIT",
  "version": "0.0.1",
  "type": "module",
  "main": "./dist/runtime/index.js",
  "types": "./dist/runtime/index.d.ts",
  "files": [
    "dist",
    "client",
    "package.json",
    "readme.md"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MrWangJustToDo/MyReact",
    "directory": "packages/myreact-lynx"
  },
  "exports": {
    ".": {
      "types": "./dist/runtime/index.d.ts",
      "import": "./dist/runtime/index.js"
    },
    "./jsx-runtime": {
      "import": "./jsx-runtime.js",
      "types": "./jsx-runtime.d.ts"
    },
    "./jsx-dev-runtime": {
      "import": "./jsx-dev-runtime.js",
      "types": "./jsx-dev-runtime.d.ts"
    },
    "./entry-background": {
      "types": "./dist/runtime/entry-background.d.ts",
      "import": "./dist/runtime/entry-background.js"
    },
    "./main-thread": {
      "types": "./dist/main-thread/entry-main.d.ts",
      "import": "./dist/main-thread/entry-main.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "import": "./dist/plugin/index.js"
    },
    "./plugin/loaders/*": {
      "import": "./dist/plugin/loaders/*.js"
    },
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "rslib build",
    "dev": "rslib build --watch"
  },
  "dependencies": {
    "@lynx-js/css-extract-webpack-plugin": "^0.7.0",
    "@lynx-js/react": "^0.116.5",
    "@lynx-js/runtime-wrapper-webpack-plugin": "^0.1.3",
    "@lynx-js/template-webpack-plugin": "^0.10.8",
    "@my-react/react-refresh": "^0.3.24",
    "@my-react/react-refresh-tools": "^0.0.35"
  },
  "devDependencies": {
    "@lynx-js/type-element-api": "0.0.3",
    "@lynx-js/types": "3.7.0",
    "@my-react/react-shared": "^0.3.24",
    "@rsbuild/core": "^1.3.0",
    "@rslib/core": "^0.19.6",
    "@rspack/core": "^1.6.5"
  },
  "peerDependencies": {
    "@my-react/react": ">=0.3.24",
    "@rsbuild/core": ">=1.0.0",
    "@rspack/core": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "@rsbuild/core": {
      "optional": true
    },
    "@rspack/core": {
      "optional": true
    }
  }
}
