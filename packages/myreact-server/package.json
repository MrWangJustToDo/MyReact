{
  "name": "@my-react/react-server",
  "description": "React Server Components support for MyReact",
  "author": "MrWangJustToDo",
  "license": "MIT",
  "version": "0.3.22",
  "main": "./index.js",
  "types": "./dist/types/index.d.ts",
  "module": "./dist/esm/index.mjs",
  "files": [
    "dist",
    "index.js",
    "server",
    "client"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/MrWangJustToDo/MyReact",
    "directory": "packages/myreact-server"
  },
  "homepage": "https://mrwangjusttodo.github.io/MyReact",
  "exports": {
    ".": {
      "types": "./dist/types/index.d.ts",
      "require": "./index.js",
      "import": "./dist/esm/index.mjs",
      "default": "./dist/esm/index.mjs"
    },
    "./server": {
      "types": "./dist/types/server/index.d.ts",
      "require": "./server/index.js",
      "import": "./dist/esm/server/index.mjs",
      "default": "./dist/esm/server/index.mjs"
    },
    "./client": {
      "types": "./dist/types/client/index.d.ts",
      "require": "./client/index.js",
      "import": "./dist/esm/client/index.mjs",
      "default": "./dist/esm/client/index.mjs"
    },
    "./package.json": "./package.json"
  },
  "buildOptions": [
    {
      "input": "./src/index.ts",
      "output": [
        {
          "dir": "./dist",
          "entryFileNames": "cjs/index.js",
          "format": "cjs",
          "type": true,
          "multiple": true
        },
        {
          "dir": "./dist",
          "entryFileNames": "esm/index.mjs",
          "format": "esm"
        }
      ]
    },
    {
      "input": "./src/server/index.ts",
      "pkgName": "server",
      "output": [
        {
          "dir": "./dist",
          "entryFileNames": "cjs/server/index.js",
          "format": "cjs",
          "multiple": true
        },
        {
          "dir": "./dist",
          "entryFileNames": "esm/server/index.mjs",
          "format": "esm"
        }
      ]
    },
    {
      "input": "./src/client/index.ts",
      "pkgName": "client",
      "output": [
        {
          "dir": "./dist",
          "entryFileNames": "cjs/client/index.js",
          "format": "cjs",
          "multiple": true
        },
        {
          "dir": "./dist",
          "entryFileNames": "esm/client/index.mjs",
          "format": "esm"
        }
      ]
    }
  ],
  "dependencies": {
    "@lazarv/rsc": "0.0.0-experimental-196ba2e-20260326-ed190390"
  },
  "devDependencies": {
    "@my-react/react-shared": "^0.3.22"
  },
  "peerDependencies": {
    "@my-react/react": ">=0.3.22",
    "@my-react/react-reconciler": ">=0.3.22"
  }
}
